def greet(name)
    say "Hello, " + name + "!";
end;

greet("world");

x = 10;
y = 3;
say x + y;

def factorial(n)
    if n < 2 then
        return 1;
    end;
    return n * factorial(n - 1);
end;

result = factorial(5);
say result;

i = 1;
while i < 6 do
    say i;
    i = i + 1;
end;

if 10 > 5 then
    say "ten is greater";
else
   say "this won't print";
end;
